# Copy to `.env` and fill in secrets. `.env` is gitignored.

# USB serial (macOS: `ls /dev/cu.*` after plugging in Arduino)
ROBOT_ARM_PORT=/dev/cu.usbmodem1401
ROBOT_ARM_AUTO_SIMULATE=0

# Arthritis motor profile: early | moderate | severe
ROBOT_ARM_MOTOR_LEVEL=moderate

# Quit gesture: peace sign hold only
ROBOT_ARM_QUIT_GESTURE=peace_hold

# Large daily-task buttons in control panel (1 = on)
ROBOT_ARM_ACCESSIBILITY=1

# Depth Anything V2 + YOLO targeting (1 = on)
ROBOT_ARM_ENABLE_DEPTH=1
ROBOT_ARM_VISION_MODEL=yolov8s.pt

# LLM: groq | google | ollama
ROBOT_ARM_LLM_PROVIDER=groq
ROBOT_ARM_TRY_OLLAMA=0

GROQ_API_KEY=
GOOGLE_API_KEY=
OLLAMA_API_KEY=
